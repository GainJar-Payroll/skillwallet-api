# ── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── Admin ─────────────────────────────────────────────────────────────────────
ADMIN_API_KEY=changeme-super-secret

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/skillwallet
MONGODB_DB_NAME=skill-wallet

# ── Executor Account ──────────────────────────────────────────────────────────
# Generate with: node -e "const {generatePrivateKey}=require('viem/accounts');console.log(generatePrivateKey())"
EXECUTOR_PRIVATE_KEY=

SPONSOR_PRIVATE_KEY=
SPONSOR_ADDRESS=
SPONSOR_FEE_CHAIN_ID=8453          # 8453 = Base mainnet, 84532 = Base Sepolia
SPONSOR_BUDGET_ATOMS=5000000       # 50 USDC per delegation cycle (500 × 10_000)
SPONSOR_REFRESH_THRESHOLD=0.8      # refresh at 80% used

# ── Blockchain RPC ────────────────────────────────────────────────────────────
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
BASE_MAINNET_RPC_URL=https://mainnet.base.org

# ── Default chain for MVP ─────────────────────────────────────────────────────
DEFAULT_CHAIN_ID=84532

# ── 1Shot Relayer ──────────────────────────────────────────────────────────────
ONESHOT_RELAYER_URL=https://relayer.1shotapi.dev/relayers
# ONESHOT_POLL_INTERVAL_MS=3000
# ONESHOT_POLL_TIMEOUT_MS=300000

# ── Venice AI (x402 wallet-auth) ──────────────────────────────────────────────
VENICE_API_BASE=https://api.venice.ai/api/v1
VENICE_MODEL=google/gemini-2.5-flash
VENICE_TOPUP_AMOUNT_USD=5

# ── x402 OttoAI Crypto News ───────────────────────────────────────────────────
OTTOAI_NEWS_URL=https://x402.ottoai.services/crypto-news

# ── Feature Flags ────────────────────────────────────────────────────────────
RUNNER_ENABLED=true

# ── CLI proof scripts only (test/proof/*.ts) ─────────────────────────────────
# Required ONLY when running bun test/proof/proof.ts or proof-trigger-dca.ts
# for the live onchain end-to-end demo. The backend runtime does not read it.
PROOF_PRIVATE_KEY=
