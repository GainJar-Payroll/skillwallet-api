# =============================================================================
# SkillWallet Core Backend — Environment Configuration
# =============================================================================
# Copy this file to `.env` and fill in the values. Missing required values
# will cause the app to crash at boot. Optional values have defaults defined
# in src/config/env.schema.ts.
#
# Bun auto-loads .env, so no dotenv import is required at runtime.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (MongoDB) — REQUIRED
# -----------------------------------------------------------------------------
# MONGODB_URI must be a valid mongodb:// or mongodb+srv:// connection string
MONGODB_URI=

# Database name (default: skillwallet)
MONGODB_DB_NAME=skill-wallet

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
# Environment: development | test | production (default: development)
NODE_ENV=development

# HTTP port (default: 4000)
PORT=4000

# Default EVM chain ID (default: 8453 = Base mainnet)
# Other common values: 84532 (Base Sepolia), 1 (Ethereum), 11155111 (Sepolia)
DEFAULT_CHAIN_ID=84532

# -----------------------------------------------------------------------------
# RPC Endpoints — OPTIONAL
# -----------------------------------------------------------------------------
# Only required when you make on-chain calls
BASE_RPC_URL=
BASE_SEPOLIA_RPC_URL=
SEPOLIA_RPC_URL=

# -----------------------------------------------------------------------------
# Smart Contract Addresses — OPTIONAL
# -----------------------------------------------------------------------------
# DelegationManager addresses (ERC-7710 / MetaMask smart-accounts-kit)
DEFAULT_DELEGATION_MANAGER_ADDRESS=
BASE_DELEGATION_MANAGER_ADDRESS=
BASE_SEPOLIA_DELEGATION_MANAGER_ADDRESS=

# Main executor address per chain (MVP 1: one executor per chain handles all skills)
# The `adapter` field in the executor registry defaults to 'multi' — all skills use
# the same executor. Per-adapter executors are not configured for MVP 1.
BASE_EXECUTOR_ADDRESS=

# Token addresses on Base (USDC and WETH for the built-in DCA skill)
BASE_USDC_ADDRESS=
BASE_WETH_ADDRESS=

# DEX router on Base (Aerodrome / Uniswap V3 / custom)
BASE_SWAP_ROUTER_ADDRESS=

# -----------------------------------------------------------------------------
# 1Shot Relayer — MANDATORY (no enable flag, service is always wired)
# -----------------------------------------------------------------------------
# 1Shot is the only supported relayer in this project. The service is always
# available; if these env vars are missing at startup, the app does NOT crash
# (boot is permissive) but relay endpoints will return NOT_CONFIGURED with a
# clear message until the values are provided.
#
# CURRENT STATUS: The current OneShotRelayerService uses a REST + Bearer auth
# shape that does NOT match the real 1Shot JSON-RPC API. Do not point this
# at https://relayer.1shotapi.com/relayers until the v2 refactor ships.
# v2 refactor: see TODO — real JSON-RPC, Ed25519 webhooks, 9 methods,
# EIP-7710 bundle shape, status codes 100/110/200/400/500.
ONESHOT_BASE_URL=
ONESHOT_API_KEY=
ONESHOT_WEBHOOK_SECRET=
