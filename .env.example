# =============================================================================
# SkillWallet Core Backend — Environment Configuration
# =============================================================================
# Copy this file to `.env` and fill in the values. Missing required values
# will cause the app to crash at boot. Optional values have defaults defined
# in src/config/env.schema.ts.
#
# Bun auto-loads .env, so no dotenv import is required at runtime.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (MongoDB) — REQUIRED
# -----------------------------------------------------------------------------
# MONGODB_URI must be a valid mongodb:// or mongodb+srv:// connection string
MONGODB_URI=

# Database name (default: skillwallet)
MONGODB_DB_NAME=skill-wallet

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
# Environment: development | test | production (default: development)
NODE_ENV=development

# HTTP port (default: 4000)
PORT=4000

# -----------------------------------------------------------------------------
# 1Shot Relayer — MANDATORY (no enable flag, service is always wired)
# -----------------------------------------------------------------------------
# 1Shot is the only supported relayer in this project. The service is always
# available; if these env vars are missing at startup, the app does NOT crash
# (boot is permissive) but relay endpoints will return NOT_CONFIGURED with a
# clear message until the values are provided.
#
# v2: 1Shot exposes a permissionless JSON-RPC API (no API key, no HMAC). The
# service speaks JSON-RPC 2.0 over HTTPS, with these methods:
#   - getCapabilities                (relayer capabilities + supported networks)
#   - getFeeData                     (fee estimate for a bundle)
#   - estimate7710Transaction        (single-chain)
#   - estimate7710TransactionMultichain
#   - send7710Transaction            (single-chain)
#   - send7710TransactionMultichain
#   - sendTransaction                (raw, single-chain)
#   - sendTransactionMultichain
#   - getStatus                      (poll task status by taskId)
#
# Relayer URL is derived from ONESHOT_NETWORK unless ONESHOT_RELAYER_URL is set:
#   mainnet → https://relayer.1shotapi.com/relayers
#   testnet → https://relayer.1shotapi.dev/relayers
ONESHOT_NETWORK=testnet
ONESHOT_RELAYER_URL=https://relayer.1shotapi.dev/relayers

# 1Shot fees are paid in an accepted ERC-20 per chain (USDC by default).
# Discover the accepted tokens via POST /relayer_getCapabilities [chainId].
# If left empty, defaults to USDC on the active chain:
#   eth mainnet (1):           0xa0b86991c6218b36c1d19d4a2e9Eb0cE3606eB48
#   eth sepolia (11155111):    0x1c7D4B196Cb0C7B01d743Fbc6116a902379C7238
#   base (8453):               0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
#   base sepolia (84532):      0x036CbD53842c5426634e7929541eC2318f3dCF7e
ONESHOT_PAYMENT_TOKEN_ADDRESS=

# Chain selection by network. Testnet default = Base Sepolia (used by /proof).
ONESHOT_TESTNET_CHAIN_ID=84532
ONESHOT_MAINNET_CHAIN_ID=8453

# -----------------------------------------------------------------------------
# Admin Auth — REQUIRED
# -----------------------------------------------------------------------------
# Secret key required as `x-api-key` header on admin-only endpoints
# (POST/PATCH /skills, POST/PATCH /executors, PATCH /installations/:id/status,
# POST /installations/:id/{pause,resume,revoke}).
# Generate with:  python3 -c "import uuid; print(uuid.uuid4())"
ADMIN_API_KEY=

# -----------------------------------------------------------------------------
# Executor Configuration — REQUIRED FOR MVP 1
# -----------------------------------------------------------------------------
# Single EOA signs all DCA + voting transactions on behalf of user smart accounts.
# Same address on all chains (derived deterministically from the private key).
# Generate a fresh 32-byte random private key (0x-prefixed) and derive its address.
EXECUTOR_PRIVATE_KEY=
EXECUTOR_ADDRESS=
