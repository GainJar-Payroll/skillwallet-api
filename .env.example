# ── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── Admin ─────────────────────────────────────────────────────────────────────
ADMIN_API_KEY=changeme-super-secret

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/skillwallet
MONGODB_DB_NAME=skill-wallet

# ── Executor Account ──────────────────────────────────────────────────────────
# Generate with: node -e "const {generatePrivateKey}=require('viem/accounts');console.log(generatePrivateKey())"
SPONSOR_PRIVATE_KEY=
SPONSOR_ADDRESS=
SPONSOR_FEE_CHAIN_ID=8453          # 8453 = Base mainnet, 84532 = Base Sepolia
SPONSOR_BUDGET_ATOMS=5000000       # 50 USDC per delegation cycle (500 × 10_000)
SPONSOR_REFRESH_THRESHOLD=0.8      # refresh at 80% used

# ── Blockchain RPC ────────────────────────────────────────────────────────────
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
BASE_MAINNET_RPC_URL=https://mainnet.base.org

# ── Default chain for MVP ─────────────────────────────────────────────────────
DEFAULT_CHAIN_ID=84532 # Base Sepolia

# ── 1Shot Relayer ──────────────────────────────────────────────────────────────
ONESHOT_RELAYER_URL=https://relayer.1shotapi.dev/relayers
# Mainnet relayer (https://relayer.1shotapi.com). Optional — falls back to testnet relayer if unset.
# ONESHOT_RELAYER_URL_MAINNET=https://relayer.1shotapi.com/relayers

# ── Venice AI (x402 wallet-auth) ──────────────────────────────────────────────
VENICE_API_BASE=https://api.venice.ai/api/v1
VENICE_MODEL=e2ee-gpt-oss-120b-p
VENICE_API_KEY=

# ── x402 OttoAI Crypto News ───────────────────────────────────────────────────
OTTOAI_NEWS_URL=https://x402.ottoai.services/crypto-news

# ── Pimlico Paymaster (ERC-4337 bundler + ERC-7677 paymaster) ──────────────
# Per-chain Pimlico URLs from https://dashboard.pimlico.io
PIMLICO_URL_BASE_SEPOLIA=https://api.pimlico.io/v2/base-sepolia/rpc?apikey=pim_xxx
PIMLICO_URL_BASE_MAINNET=https://api.pimlico.io/v2/base/rpc?apikey=pim_xxx
# Sponsorship policy IDs (one per chain, from Pimlico dashboard)
PIMLICO_POLICY_BASE_SEPOLIA=sp_xxx
PIMLICO_POLICY_BASE_MAINNET=sp_xxx
# API key for Pimlico admin endpoints (guards POST /pimlico/*)
PIMLICO_EXEC_KEY=changeme-pimlico-secret
# Legacy single-chain env vars (still supported as fallback)
# PAYMASTER_URL=...
# BUNDLER_URL=...
# SPONSORSHIP_POLICY=...

# ── Feature Flags ────────────────────────────────────────────────────────────
RUNNER_ENABLED=true

# ── CLI proof scripts only (test/proof/*.ts) ─────────────────────────────────
# Required ONLY when running bun test/proof/proof.ts or proof-trigger-dca.ts
# for the live onchain end-to-end demo. The backend runtime does not read it.
PROOF_PRIVATE_KEY=

# ── Cron Runner ────────────────────────────────────────────────────────────────
# Standard cron expression. Read every 5 minutes by default.
# Format: minute hour day-of-month month day-of-week
# Examples:
#   */5 * * * *   → every 5 minutes (default)
#   0 */6 * * *   → every 6 hours
#   0 9 * * 1-5   → 9 AM weekdays only
CRON_INTERVAL=*/5 * * * *