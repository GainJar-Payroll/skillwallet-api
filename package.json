{
  "name": "skillwallet-backend",
  "version": "1.0.0",
  "description": "NestJS backend for SkillWallet Marketplace",
  "private": true,
  "main": "dist/main.js",
  "scripts": {
    "build": "nest build",
    "build:swc": "nest build --builder swc",
    "start": "node dist/main.js",
    "start:dev": "nest start --watch --builder swc",
    "start:debug": "nest start --debug --watch --builder swc",
    "test": "jest --config jest.config.cjs",
    "test:watch": "jest --config jest.config.cjs --watch",
    "test:cov": "jest --config jest.config.cjs --coverage",
    "test:e2e": "jest --config jest.config.cjs --testPathPattern=e2e",
    "lint": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@metamask/smart-accounts-kit": "^1.6.0",
    "@nestjs/common": "^10",
    "@nestjs/config": "^3",
    "@nestjs/core": "^10",
    "@nestjs/mongoose": "^10",
    "@nestjs/platform-express": "^10",
    "@nestjs/schedule": "^4",
    "@nestjs/swagger": "^11.4.4",
    "@nestjs/testing": "^10",
    "@nestjs/throttler": "^5",
    "@x402/evm": "^2.14.0",
    "@x402/fetch": "^2.14.0",
    "class-validator": "^0.15.1",
    "cron-parser": "^4",
    "dotenv": "^17.4.2",
    "joi": "^17",
    "mongoose": "^8",
    "reflect-metadata": "^0.2",
    "rxjs": "^7",
    "viem": "^2.52.2",
    "x402": "^0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10",
    "@nestjs/schematics": "^10",
    "@swc/cli": "^0.7.0",
    "@swc/core": "^1.13.0",
    "@swc/jest": "^0.2.39",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.14",
    "@types/node": "^20",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^10.1.4",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10",
    "tsconfig-paths": "^4",
    "typescript": "^5"
  }
}
